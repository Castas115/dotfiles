{
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Edit",
      "Write",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(ls *)",
      "Bash(pwd)",
      "Bash(which *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(find *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(kubectl get *)",
      "Bash(kubectl describe *)",
      "Bash(kubectl logs *)",
      "Bash(kubectl top *)",
      "Bash(kubectl config *)",
      "Bash(kubectx *)",
      "Bash(kubens *)",
      "Bash(az account *)",
      "Bash(az group list *)",
      "Bash(az resource list *)",
      "Bash(az vm list *)",
      "Bash(az aks list *)",
      "Bash(az aks get-credentials *)",
      "Bash(az storage *)",
      "Bash(az network *)",
      "Bash(az ad *)",
      "Bash(az keyvault *)",
      "Bash(az acr *)",
      "Bash(az webapp *)",
      "Bash(az functionapp *)",
      "Task"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jon/.claude/hooks/notify-dashboard.sh PreToolUse",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jon/.claude/hooks/notify-dashboard.sh SubagentStart",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "/home/jon/.claude/hooks/notify-dashboard.sh SubagentStop",
            "timeout": 5,
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/home/jon/.spacecake/.app/hooks/statusline.sh"
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Oh, it is you my master. Is it time to lay waste of this world?",
      "Calling to: Network Mike 😎 ",
      "Latigando chechenos",
      "Bombeting",
      "¿Te gusta mi bachata?",
      "Pionexing"
    ]
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  }
}
